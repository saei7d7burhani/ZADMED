<main class="page-shell">
	<header class="topbar">
		<div class="brand">
			<img src="/logo.svg" alt="ZADMED logo" width="136" height="36" />
		</div>
		<button id="lang-toggle" class="lang-btn" type="button" aria-live="polite">
			العربية
		</button>
	</header>

	<section class="hero card">
		<p class="eyebrow" data-i18n="eyebrow">Reliable Digital Healthcare</p>
		<h1 data-i18n="title">ZADMED brings care closer to everyone</h1>
		<p class="lead" data-i18n="lead">
			A modern platform for clinics and patients with secure records, instant appointments, and
			clear communication.
		</p>

		<div class="actions">
			<a class="btn btn-primary" href="#" data-i18n="primaryCta">Get Started</a>
			<a class="btn btn-secondary" href="#" data-i18n="secondaryCta">Learn More</a>
		</div>
	</section>

	<section class="features">
		<article class="feature card">
			<h2 data-i18n="feature1Title">Smart Appointments</h2>
			<p data-i18n="feature1Body">Book, manage, and receive reminders in a few clicks.</p>
		</article>
		<article class="feature card">
			<h2 data-i18n="feature2Title">Secure Medical Records</h2>
			<p data-i18n="feature2Body">Protected data with role-based access and modern encryption.</p>
		</article>
		<article class="feature card">
			<h2 data-i18n="feature3Title">Bilingual Experience</h2>
			<p data-i18n="feature3Body">Full Arabic and English support with proper RTL/LTR layout.</p>
		</article>
	</section>
</main>

<script is:inline>
	const translations = {
		en: {
			eyebrow: 'Reliable Digital Healthcare',
			title: 'ZADMED brings care closer to everyone',
			lead: 'A modern platform for clinics and patients with secure records, instant appointments, and clear communication.',
			primaryCta: 'Get Started',
			secondaryCta: 'Learn More',
			feature1Title: 'Smart Appointments',
			feature1Body: 'Book, manage, and receive reminders in a few clicks.',
			feature2Title: 'Secure Medical Records',
			feature2Body: 'Protected data with role-based access and modern encryption.',
			feature3Title: 'Bilingual Experience',
			feature3Body: 'Full Arabic and English support with proper RTL/LTR layout.',
			toggle: 'العربية'
		},
		ar: {
			eyebrow: 'رعاية صحية رقمية موثوقة',
			title: 'زادمِد يقرّب الرعاية الصحية للجميع',
			lead: 'منصة حديثة للعيادات والمرضى بسجلات آمنة، مواعيد فورية، وتواصل واضح.',
			primaryCta: 'ابدأ الآن',
			secondaryCta: 'اعرف المزيد',
			feature1Title: 'مواعيد ذكية',
			feature1Body: 'احجز وأدر المواعيد واستلم التذكيرات بخطوات بسيطة.',
			feature2Title: 'سجلات طبية آمنة',
			feature2Body: 'بيانات محمية بصلاحيات دقيقة وتشفير حديث.',
			feature3Title: 'تجربة ثنائية اللغة',
			feature3Body: 'دعم كامل للعربية والإنجليزية مع تخطيط RTL/LTR صحيح.',
			toggle: 'English'
		}
	};

	const root = document.documentElement;
	const button = document.getElementById('lang-toggle');

	const applyLanguage = (lang) => {
		const strings = translations[lang];
		root.lang = lang;
		root.dir = lang === 'ar' ? 'rtl' : 'ltr';
		document.body.classList.toggle('rtl', lang === 'ar');
		document.querySelectorAll('[data-i18n]').forEach((element) => {
			const key = element.getAttribute('data-i18n');
			if (key && strings[key]) {
				element.textContent = strings[key];
			}
		});
		button.textContent = strings.toggle;
		localStorage.setItem('zadmed-lang', lang);
	};

	const initial = localStorage.getItem('zadmed-lang');
	const startLang = initial === 'ar' ? 'ar' : 'en';
	applyLanguage(startLang);

	button?.addEventListener('click', () => {
		const nextLang = root.lang === 'ar' ? 'en' : 'ar';
		applyLanguage(nextLang);
	});
</script>
