---
import { whyFeatures } from "../../data/whyFeatures.ts";
---

<section class="why" id="why">
  <div class="section-label" data-i18n="why.label">Why Choose Us</div>
  <h2 class="section-title" data-i18n="why.title">Not All Medical Partners<br />Are The Same</h2>
  <p class="section-sub" data-i18n="why.subtitle">
    We bring the most innovative cardiovascular technologies to your practice,
    backed by clinical evidence and dedicated support.
  </p>

  <div class="why-grid">
    <div class="why-features">
      {whyFeatures.map(feature => (
        <div class="feature-item">
          <div class="feature-icon">{feature.icon}</div>
          <div>
            <h3 data-i18n={feature.titleKey}>{feature.fallbackTitle}</h3>
            <p data-i18n={feature.descKey}>{feature.fallbackDesc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="why-visual">
      <div class="why-card-main">
        <h3 data-i18n="why.card.title">Life Deserves The Best</h3>
        <p data-i18n="why.card.desc">
          We partner with world-leading manufacturers to bring you the most
          advanced coronary intervention solutions available, rigorously
          tested, CE certified, and trusted by cardiologists globally.
        </p>
        <div class="why-card-mini">
          <div class="mini-stat">
            <span class="n">2013</span>
            <span class="l">Market Reference</span>
          </div>
          <div class="mini-stat">
            <span class="n">72</span>
            <span class="l">Stent Sizes</span>
          </div>
          <div class="mini-stat">
            <span class="n">28</span>
            <span class="l">Balloon Sizes</span>
          </div>
          <div class="mini-stat">
            <span class="n">CE</span>
            <span class="l">Certified</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>