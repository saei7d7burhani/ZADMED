---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="page-intro">
  <div class="page-intro-inner">
    <div class="section-label">{eyebrow}</div>
    <h1 class="page-title">{title}</h1>
    <p class="page-description">{description}</p>
  </div>
</section>