<section class="contact-section">
  <div class="contact-grid">
    <div class="contact-copy">
      <div class="section-label">Contact Details</div>
      <h2 class="section-title">Talk to the ZADMED team</h2>
      <p class="section-sub">
        Reach out for product information, sampling requests, or clinical support for your institution.
      </p>

      <div class="contact-cards">
        <a class="contact-card" href="mailto:info@zadmed.com">
          <span class="contact-card-label">Email</span>
          <span class="contact-card-value">info@zadmed.com</span>
        </a>
        <a class="contact-card" href="tel:+0000000000">
          <span class="contact-card-label">Phone</span>
          <span class="contact-card-value">+00 000 000 000</span>
        </a>
        <div class="contact-card">
          <span class="contact-card-label">Response time</span>
          <span class="contact-card-value">Within 1 business day</span>
        </div>
      </div>
    </div>

    <form class="contact-form" action="mailto:info@zadmed.com" method="post" enctype="text/plain">
      <label class="field">
        <span>Name</span>
        <input type="text" name="name" placeholder="Your name" />
      </label>
      <label class="field">
        <span>Email</span>
        <input type="email" name="email" placeholder="Your email" />
      </label>
      <label class="field">
        <span>Message</span>
        <textarea name="message" rows="6" placeholder="How can we help?"></textarea>
      </label>
      <button type="submit" class="btn-primary contact-submit">Send Message</button>
    </form>
  </div>
</section>