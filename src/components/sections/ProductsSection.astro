---
import { products } from "../../data/products.ts";
import ProductCard from "./ProductCard.astro";
---

<section class="products" id="products">
  <div class="products-header">
    <div>
      <div class="section-label" data-i18n="products.label">Our Portfolio</div>
      <h2 class="section-title" data-i18n="products.title">Cardiovascular Solutions</h2>
    </div>
  </div>

  <div class="products-grid">
    {products.map((product) => (
      <ProductCard
        tag={product.category}
        tagKey={product.categoryKey}
        title={product.name}
        titleKey={product.nameKey}
        description={product.description}
        descKey={product.descKey}
        accentColor={product.styleTheme === 'xlimus' ? 'var(--blue-deep)' : 'var(--blue-mid)'}
        tagColor={product.styleTheme === 'xlimus' ? 'rgba(11, 30, 110, 0.1)' : 'rgba(26, 58, 204, 0.1)'}
        image={product.image}
        features={product.features}
        specs={product.specs}
        linkHref={product.link}
      />
    ))}
  </div>
</section>