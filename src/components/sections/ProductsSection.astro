---
import { products } from "../../data/products.ts";
---

<section class="products" id="products">
  <div class="products-header">
    <div>
      <div class="section-label">Our Portfolio</div>
      <h2 class="section-title">Cardiovascular Solutions</h2>
    </div>
    <p class="section-sub products-copy">
      Two flagship products addressing the full spectrum of coronary artery disease treatment.
    </p>
  </div>

  <div class="products-grid">
    {products.map((product) => (
      <article class="product-card">
        <div class={`product-card-top ${product.styleTheme === 'xlimus' ? 'xlimus-top' : ''}`}>
          <div class={`product-tag ${product.styleTheme === 'xlimus' ? 'xlimus-tag' : ''}`}>{product.category}</div>
          <h3>{product.name}</h3>
          <p>{product.description}</p>
        </div>
        <div class="product-card-body">
          <ul class="product-features">
            {product.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
          <div class="product-specs">
            {product.specs.map((spec) => (
              <div class="spec">
                <div class="sk">{spec.label}</div>
                <div class="sv">{spec.value}</div>
              </div>
            ))}
          </div>
          <a href={product.link} class={`product-link ${product.styleTheme === 'xlimus' ? 'xlimus-link' : ''}`}>
            Request Information <span class="arrow">&rarr;</span>
          </a>
        </div>
      </article>
    ))}
  </div>
</section>