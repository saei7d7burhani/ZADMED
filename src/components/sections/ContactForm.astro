---
// src/components/sections/ContactForm.astro
---

<section class="contact-form-wrapper">
  <div class="contact-form-grid">
    <!-- Form Side (Left) -->
    <div class="form-side">
      <div class="form-header">
        <h2 data-i18n="contact.title">Send us a Message</h2>
        <p data-i18n="contact.subtitle">Fill in your details and
 
  we'll get back to you as soon as possible.</p>
      </div>

      <form id="contact-form" class="styled-form" action="https://api.web3forms.com/submit" method="POST" novalidate>
        <input type="hidden" name="access_key" value="0eacdc28-8866-4fed-a901-1e7a2c1f65cf" />
        <input type="hidden" name="subject" value="New message from ZADMED website" />
        <input type="hidden" name="from_name" value="ZADMED Website" />
        <input type="checkbox" name="botcheck" style="display: none;" tabindex="-1" autocomplete="off" />
        <div class="form-row">
          <label class="field-label" for="user-phone">
        <span data-i18n="contact.form.phone">Phone Number</span>
      <input type="tel" id="user-phone" name="phone"
        data-i18n-placeholder="contact.form.phonePlaceholder"
          placeholder="+963-11-0000000" required />
      </label>

          <label class="field-label" for="user-email">
            <span data-i18n="contact.form.email">Email Address</span>
            <input type="email" id="user-email" name="email" data-i18n-placeholder="contact.form.emailPlaceholder" placeholder="you@example.com" required />
          </label>
        </div>

    

        <label class="field-label" for="user-message">
          <span data-i18n="contact.form.message">Message</span>
          <textarea id="user-message" name="message" rows="5" data-i18n-placeholder="contact.form.messagePlaceholder" placeholder="How can we help?" required></textarea>
        </label>

        <div class="form-footer">
          <button type="submit" class="submit-btn" id="submit-btn">
            <span class="btn-text" data-i18n="contact.form.submit">Send Message</span>
            <span class="btn-spinner" style="display: none;" data-i18n="contact.form.sending">Wait...</span>
          </button>
          <div id="form-msg" class="form-msg" style="display: none;"></div>
        </div>
      </form>
    </div>

    <!-- Contact Info Blocks (Right) -->
    <div class="info-side">
      <h3 data-i18n="contact.info.title">Contact Information</h3>
      <p data-i18n="contact.info.desc">Whether you're looking for product samples, technical support, or billing information, we are here to assist you.</p>

      <div class="info-blocks">
        <div class="info-block">
          <span class="info-label" data-i18n="contact.info.office.label">Corporate Office</span>
          <span class="info-value" data-i18n="contact.info.office.value">123 Health Ave, Suite 400<br/>Medical District</span>
        </div>
        
        <div class="info-block">
           <span class="info-label" data-i18n="contact.info.direct.label">Direct Contact</span>
  <span class="info-value">
    +963-11-2310855<br/>
    +963-11-2314041<br/>
    +963-96-5255502<br/>
    +963-96-5255501<br/>
    info@zadmed.org
  </span>
        </div>

        <div class="info-block">
          <span class="info-label" data-i18n="contact.info.hours.label">Support Hours</span>
          <span class="info-value" data-i18n="contact.info.hours.value">Sat - Thur: 9:00 AM - 4:00 PM<br/>Response usually within 1 business day</span>
        </div>
      </div>
    </div>
  
  <div class="map-embed">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3327.4!2d36.303788!3d33.518302!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1518e756ac67fbab%3A0x4e6e915933c18458!2z2KzZhduo2YrYqSDYp9mE2KrZhtmF2YrYqSDZiNin2Kra2YjYt9mK2LEg2YTZhNiu2YrYsiwg2K46INin2YQtOU0yMzEwODU1!5e0!3m2!1sen!2s!4v1700000000000!5m2!1sen!2s"
      width="100%"
      height="260"
      style="border:0; border-radius: 16px; display: block;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="ZADMED office location">
    </iframe>
  </div>
  </div>
</section>

<style>
.map-embed {
  margin-top: 20px;
  border-radius: 16px;
  overflow: hidden;
  grid-column: 1 / -1;
}
  .contact-form-wrapper {
    margin: 40px 0;
    font-family: inherit;
  }
  
  .contact-form-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: flex-start;
  }

  .form-side {
    background: #ffffff;
    border: 1px solid var(--border, #e5e7eb);
    padding: 32px;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }

  .form-header {
    margin-bottom: 24px;
  }

  .form-header h2 {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--blue-deep, #0b1e6e);
    margin-bottom: 8px;
  }

  .form-header p {
    color: var(--text-muted, #64748b);
    font-size: 15px;
  }

  .styled-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .field-label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 14px;
    color: var(--text-dark, #1e293b);
    font-weight: 600;
  }

  .styled-form input,
  .styled-form select,
  .styled-form textarea {
    width: 100%;
    padding: 12px 14px;
    border-radius: 8px;
    border: 1px solid var(--border, #e5e7eb);
    background: #f9fafb;
    font-size: 15px;
    color: var(--text-dark, #1e293b);
    font-family: inherit;
    transition: all 0.2s;
  }

  .styled-form input:focus,
  .styled-form select:focus,
  .styled-form textarea:focus {
    outline: none;
    border-color: var(--accent, var(--blue-mid, #1a3acc));
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(26, 58, 204, 0.1);
  }

  .form-footer {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 8px;
  }

  .submit-btn {
    background: var(--blue-mid, #1a3acc);
    color: #ffffff;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    min-width: 160px;
    display: flex;
    justify-content: center;
  }

  .submit-btn:hover {
    background: var(--blue-deep, #0b1e6e);
    transform: translateY(-1px);
  }
  
  .submit-btn:disabled {
    background: #94a3b8;
    cursor: not-allowed;
    transform: none;
  }

  .form-msg {
    font-size: 14px;
    font-weight: 600;
  }
  
  .msg-success { color: #16a34a; }
  .msg-error { color: #dc2626; }

  .info-side {
    background: linear-gradient(135deg, var(--blue-deep, #0b1e6e), var(--blue-mid, #1a3acc));
    color: #ffffff;
    padding: 32px;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }

  .info-side h3 {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 12px;
    color: var(--gold, #f5a800);
  }

  .info-side p {
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 32px;
    color: rgba(255, 255, 255, 0.85);
  }

  .info-blocks {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }
  
  .info-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .info-label {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 700;
  }

  .info-value {
    font-size: 15px;
    line-height: 1.5;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .contact-form-grid {
      grid-template-columns: 1fr;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  /* ── RTL Overrides ── */
  html[dir="rtl"] .contact-form-grid {
    direction: rtl;
  }

  html[dir="rtl"] .form-header h2,
  html[dir="rtl"] .form-header p {
    text-align: right;
  }

  html[dir="rtl"] .field-label {
    text-align: right;
  }

  html[dir="rtl"] .styled-form input,
  html[dir="rtl"] .styled-form textarea {
    text-align: right;
    direction: rtl;
  }

  html[dir="rtl"] .info-side h3,
  html[dir="rtl"] .info-side p,
  html[dir="rtl"] .info-label,
  html[dir="rtl"] .info-value {
    text-align: right;
  }

  html[dir="rtl"] .form-footer {
    flex-direction: row-reverse;
  }
</style>

<script>
  function updatePlaceholders() {
    const lang = localStorage.getItem('lang') || 'en';
    document.querySelectorAll<HTMLElement>('[data-i18n-placeholder]').forEach((el) => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (!key) return;
      const translations = (window as any).__zadmedTranslations;
      if (translations?.[lang]?.[key]) {
        (el as HTMLInputElement | HTMLTextAreaElement).placeholder = translations[lang][key];
      }
    });
  }

  window.addEventListener('langchange', updatePlaceholders);
  document.addEventListener('DOMContentLoaded', updatePlaceholders);
</script>
</script>