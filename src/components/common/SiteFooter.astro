---
import { footerLinks } from "../../data/navigation.ts";
import CompanyLocation from "./CompanyLocation.astro";
---

<footer>
  <div class="footer-grid">
    <div class="footer-brand">
  <a href="/" class="logo-img">
  <img 
    src="/images/ZADMEDlogo.svg" 
    alt="ZADMED Logo" 
    class="logo-img"
  />
</a>
      <p data-i18n="footer.desc">
        Advanced cardiovascular medical instruments,
        delivering innovative technology and proven clinical
        performance to healthcare professionals.
      </p>
    </div>
    <div class="footer-col">
      <h4 data-i18n="footer.nav">Navigation</h4>
      <ul>
        {footerLinks.navigation.map(link => (
          <li><a href={link.href} data-i18n={link.labelKey}>{link.labelKey === 'nav.home' ? 'Home' : link.labelKey === 'nav.about' ? 'About' : link.labelKey === 'nav.products' ? 'Products' : link.labelKey === 'nav.contact' ? 'Contact' : link.labelKey}</a></li>
        ))}
      </ul>
    </div>
    <div class="footer-col">
      <h4 data-i18n="footer.products">Products</h4>
      <ul>
        {footerLinks.products.map(link => (
          <li><a href={link.href} set:html={link.label}></a></li>
        ))}
      </ul>
    </div>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span data-i18n="footer.copyright">&copy; 2026 ZADMED. All rights reserved.</span>
    <a href="mailto:info@zadmed.com">info@zadmed.com</a>
    <CompanyLocation />
  </div>
</footer>

<style>
  .logo-img {
    height: 128px;        /* controls how tall it appears in nav */
    width: auto;         /* keeps aspect ratio */
    object-fit: contain;
  }
</style>