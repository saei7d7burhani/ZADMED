---
import { navLinks } from "../../data/navigation.ts";
import LangToggle from "./LangToggle.astro";

const currentPath = Astro.url.pathname;
const isRtl = currentPath.startsWith('/ar');

// Helper to determine if link is active
const isActive = (href: string) => {
  if (href === '/' || href === '/ar' || href === '/ar/') {
    return currentPath === href || currentPath === href + '/';
  }
  // Ignore language prefix mapping for exact matches if needed
  // A simple include will work for main sections
  return currentPath.includes(href.replace('/ar', ''));
};
---

<nav>
<a href={isRtl ? "/ar" : "/"} class="logo-wrap">
  <img 
    src="/images/ZADMEDlogo.svg" 
    alt="ZADMED Logo" 
    class="logo-img"
  />
  <span class="logo-text">ZAD<span>MED</span></span>
</a>
  <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle navigation menu">
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
  </button>
  <ul class="nav-links" id="primary-nav">
    {navLinks.map(link => {
      const targetHref = isRtl ? (link.href === '/' ? '/ar' : `/ar${link.href}`) : link.href;
      return (
        <li>
          <a 
            href={targetHref} 
            data-i18n={link.labelKey}
            class={currentPath === targetHref || currentPath === targetHref + '/' ? 'active-link' : ''}
          >
            {link.labelKey === 'nav.home' ? 'Home' : link.labelKey === 'nav.about' ? 'About' : link.labelKey === 'nav.products' ? 'Products' : link.labelKey}
          </a>
        </li>
      );
    })}
    <li>
      <a 
        href={isRtl ? "/ar/contact" : "/contact"} 
        class={`nav-cta ${currentPath.includes('/contact') ? 'active-link' : ''}`} 
        data-i18n="nav.contactCta"
      >
        Contact Us
      </a>
    </li>
    <li><LangToggle /></li>
  </ul>
</nav>

<script>
  const nav = document.querySelector("nav");
  const toggle = document.querySelector(".nav-toggle");
  const links = document.querySelector(".nav-links");

  if (nav && toggle && links) {
    const setOpen = (open: boolean) => {
      nav.classList.toggle("nav-open", open);
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    };

    toggle.addEventListener("click", () => {
      const isOpen = nav.classList.contains("nav-open");
      setOpen(!isOpen);
    });

    links.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 600) {
        setOpen(false);
      }
    });
  }
</script>

<style>
  .logo-img {
    height: 64px;        /* controls how tall it appears in nav */
    width: auto;         /* keeps aspect ratio */
    object-fit: contain;
  }
  .logo-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}

.logo-text {
  font-family: 'Inter', sans-serif;
  font-size: 22px;
  font-weight: 800;
  letter-spacing: 0.08em;
  color: #ffffff;
  line-height: 1;
}

.logo-text span {
  color: var(--gold, #f5a800);
}
</style>