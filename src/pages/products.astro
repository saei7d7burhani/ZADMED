---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import ProductsSection from "../components/sections/ProductsSection.astro";
import SiteFooter from "../components/common/SiteFooter.astro";
import SiteHeader from "../components/common/SiteHeader.astro";
---

<BaseLayout title="ZADMED Products" description="Browse ZADMED's cardiovascular product portfolio.">
  <SiteHeader />
  <main>
    <PageIntro
      eyebrow="Products"
      eyebrowKey="nav.products"
      title="A focused portfolio for coronary intervention"
      titleKey="page.products.title"
      description="Explore the flagship product lines designed to address a broad spectrum of coronary artery disease treatment needs."
      descKey="page.products.desc"
    />
    <ProductsSection />
  </main>
  <SiteFooter />
</BaseLayout>