---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import ContactCta from "../components/sections/ContactCta.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import SiteFooter from "../components/common/SiteFooter.astro";
import SiteHeader from "../components/common/SiteHeader.astro";
---

<BaseLayout title="Contact ZADMED" description="Contact ZADMED for product information, samples, and clinical support.">
  <SiteHeader />
  <main>
    <PageIntro
      eyebrow="Contact Us"
      title="Start a conversation with our team"
      description="Use the form below or reach out directly for product inquiries, sample requests, and institutional support."
    />
    <ContactSection />
    <ContactCta />
  </main>
  <SiteFooter />
</BaseLayout>