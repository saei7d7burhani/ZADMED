---
import AboutSection from "../components/sections/AboutSection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import SiteFooter from "../components/common/SiteFooter.astro";
import SiteHeader from "../components/common/SiteHeader.astro";
import WhySection from "../components/sections/WhySection.astro";
---

<BaseLayout title="About ZADMED" description="Learn more about ZADMED's mission, clinical focus, and cardiovascular solutions.">
  <SiteHeader />
  <main>
    <PageIntro
      eyebrow="About Us"
      eyebrowKey="nav.about"
      title="Built around better cardiovascular outcomes"
      titleKey="page.about.title"
      description="Discover how ZADMED combines clinical evidence, product expertise, and long-term support to serve healthcare professionals."
      descKey="page.about.desc"
    />
    <AboutSection />
    <WhySection />
  </main>
  <SiteFooter />
</BaseLayout>