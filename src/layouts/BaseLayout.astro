---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ZADMED - Advanced Cardiovascular Solutions",
  description = "Precision tools for life-saving cardiovascular interventions.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/ZADMEDlogo.svg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />
    
    <!-- Initialize language check and translation listeners globally -->
    <script>
      import "../scripts/i18n.ts";
    </script>
  </body>
</html>